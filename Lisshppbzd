<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <!-- Важно для iPhone: масштаб и запрет скролла -->
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>С днём рождения, Лизонька! 💕</title>
    <!-- Красивые рукописные шрифты -->
    <link href="https://fonts.googleapis.com/css2?family=Caveat:wght@400..700&family=Pacifico&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            -webkit-tap-highlight-color: transparent; /* убираем серый фон при тапе на iPhone */
        }
        body {
            min-height: 100vh;
            background: linear-gradient(145deg, #ffe6f0 0%, #ffd9e8 40%, #fbc4d5 100%);
            font-family: 'Caveat', cursive;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            position: relative;
            cursor: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"><path fill="%23ff69b4" d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>') 12 12, auto;
        }
        /* Заголовок */
        .title {
            position: absolute;
            top: 10px;
            left: 0;
            width: 100%;
            text-align: center;
            font-family: 'Pacifico', cursive;
            font-size: clamp(2.5rem, 10vw, 4rem);
            color: #b34180;
            text-shadow: 2px 2px 0 #ffb6c1, 4px 4px 10px rgba(255, 105, 180, 0.4);
            z-index: 10;
            pointer-events: none;
            animation: glow 3s ease-in-out infinite;
            padding: 0 10px;
        }
        @keyframes glow {
            0%, 100% { filter: drop-shadow(0 0 2px #ff9eb5); }
            50% { filter: drop-shadow(0 0 15px #ff4080); }
        }
        /* Подпись */
        .subtitle {
            position: absolute;
            bottom: 15px;
            right: 20px;
            font-size: clamp(1.5rem, 6vw, 2.2rem);
            color: #d44e8c;
            opacity: 0.9;
            font-family: 'Caveat', cursive;
            z-index: 10;
            pointer-events: none;
            transform: rotate(-5deg);
            background: rgba(255,255,240,0.4);
            padding: 0.2rem 1rem;
            border-radius: 50px;
            backdrop-filter: blur(4px);
        }
        /* Инструкция */
        .hint {
            position: absolute;
            bottom: 15px;
            left: 20px;
            background: rgba(255, 240, 245, 0.7);
            backdrop-filter: blur(4px);
            padding: 0.5rem 1.2rem;
            border-radius: 40px;
            font-size: clamp(1.2rem, 5vw, 1.8rem);
            color: #a53f6c;
            box-shadow: 0 4px 10px rgba(255, 105, 180, 0.3);
            border: 1px solid #ffa0c5;
            z-index: 10;
            font-family: 'Caveat', cursive;
            pointer-events: none;
            white-space: nowrap;
        }
        .hint span {
            display: inline-block;
            animation: bounce 1.2s infinite;
        }
        @keyframes bounce {
            0%,100%{ transform: translateY(0); }
            50%{ transform: translateY(-5px); }
        }
        canvas {
            display: block;
            width: 100vw;
            height: 100vh;
            position: absolute;
            top: 0;
            left: 0;
            z-index: 1;
            touch-action: none; /* запрещаем прокрутку и масштабирование жестами */
        }
    </style>
</head>
<body>
    <h1 class="title">✨ Лизонька, с днём рождения! ✨</h1>
    <div class="subtitle">Ты самое прекрасное, что есть 💗</div>
    <div class="hint"><span>👉</span> коснись любой картинки — станет сердечком <span>👈</span></div>
    <canvas id="birthdayCanvas"></canvas>

    <script>
        (function() {
            const canvas = document.getElementById('birthdayCanvas');
            const ctx = canvas.getContext('2d');

            let width, height;
            function resizeCanvas() {
                width = window.innerWidth;
                height = window.innerHeight;
                canvas.width = width;
                canvas.height = height;
            }
            window.addEventListener('resize', resizeCanvas);
            resizeCanvas();

            // ---- Массив летающих объектов ----
            let elements = [];

            // ---- База с 3D-картинками (PNG с прозрачным фоном) ----
            // Используем изображения с 3dicons.co — бесплатный ресурс с MIT-лицензией [citation:1]
            const imageUrls = [
                // Котики
                { type: 'cat', url: 'https://img.3dicons.co/2024m/03/0325-cat.png', size: 90 },
                { type: 'cat', url: 'https://img.3dicons.co/2024m/04/0425-kitten.png', size: 90 },
                { type: 'cat', url: 'https://img.3dicons.co/2024m/02/0225-cat.png', size: 100 },
                // Сердечки
                { type: 'heart', url: 'https://img.3dicons.co/2024m/02/0225-heart.png', size: 80 },
                { type: 'heart', url: 'https://img.3dicons.co/2024m/03/0325-heart.png', size: 85 },
                { type: 'heart', url: 'https://img.3dicons.co/2024m/01/0125-heart.png', size: 90 },
                // Цветочки
                { type: 'flower', url: 'https://img.3dicons.co/2024m/04/0425-flower.png', size: 80 },
                { type: 'flower', url: 'https://img.3dicons.co/2024m/03/0325-flower.png', size: 85 },
                { type: 'flower', url: 'https://img.3dicons.co/2024m/02/0225-flower.png', size: 90 },
                // Розовые стринги (используем подходящие иконки нижнего белья)
                { type: 'panties', url: 'https://img.3dicons.co/2024m/04/0425-lingerie.png', size: 80 },
                { type: 'panties', url: 'https://img.3dicons.co/2024m/03/0325-bra.png', size: 85 },
                // Вкусняшки
                { type: 'yummy', url: 'https://img.3dicons.co/2024m/04/0425-cupcake.png', size: 85 },
                { type: 'yummy', url: 'https://img.3dicons.co/2024m/03/0325-cake.png', size: 90 },
                { type: 'yummy', url: 'https://img.3dicons.co/2024m/02/0225-candy.png', size: 75 },
                { type: 'yummy', url: 'https://img.3dicons.co/2024m/01/0125-ice-cream.png', size: 85 },
                { type: 'yummy', url: 'https://img.3dicons.co/2024m/04/0425-donut.png', size: 80 },
                // Текстовые поздравления (оставим эмодзи для надписей — они легче и красивее смотрятся как текст)
                { type: 'text', content: 'С днём рождения!', color: '#c71585', size: 36, font: 'Caveat' },
                { type: 'text', content: 'Лизонька 💖', color: '#d83d7a', size: 42, font: 'Pacifico' },
                { type: 'text', content: 'Ты чудо!', color: '#b34180', size: 34, font: 'Caveat' },
                { type: 'text', content: 'Обожаю тебя', color: '#e667af', size: 34, font: 'Caveat' },
                { type: 'text', content: 'Самая красивая', color: '#d43f8c', size: 36, font: 'Caveat' },
            ];

            // Загружаем изображения
            const images = [];
            imageUrls.forEach((item, index) => {
                if (item.url) {
                    const img = new Image();
                    img.crossOrigin = 'anonymous'; // важно для загрузки с другого домена
                    img.src = item.url;
                    img.onload = () => {
                        // когда изображение загрузится, обновляем отрисовку
                    };
                    images.push({
                        img: img,
                        type: item.type,
                        size: item.size,
                        originalItem: item
                    });
                } else {
                    // это текстовый элемент
                    images.push({
                        type: 'text',
                        content: item.content,
                        color: item.color,
                        size: item.size,
                        font: item.font,
                        originalItem: item
                    });
                }
            });

            // Функция создания случайного элемента
            function createRandomElement() {
                const randomIndex = Math.floor(Math.random() * images.length);
                const imgData = images[randomIndex];
                
                // Базовая структура элемента
                return {
                    x: Math.random() * width,
                    y: Math.random() * height,
                    vx: (Math.random() - 0.5) * 1.4,
                    vy: (Math.random() - 0.5) * 1.4,
                    type: imgData.type,
                    imgData: imgData,
                    size: (imgData.size || 80) * (0.8 + Math.random() * 0.6),
                    rotation: (Math.random() - 0.5) * 0.2,
                    // Для текстовых элементов
                    content: imgData.content,
                    color: imgData.color,
                    font: imgData.font,
                };
            }

            // Заполняем элементами
            const count = Math.min(40, Math.floor(width * height / 20000));
            for (let i = 0; i < count; i++) {
                elements.push(createRandomElement());
            }

            // Отрисовка
            function draw() {
                ctx.clearRect(0, 0, width, height);
                
                for (let el of elements) {
                    ctx.save();
                    ctx.translate(el.x, el.y);
                    ctx.rotate(el.rotation);
                    
                    if (el.imgData && el.imgData.img && el.imgData.img.complete) {
                        // Рисуем изображение
                        ctx.drawImage(el.imgData.img, -el.size/2, -el.size/2, el.size, el.size);
                    } else if (el.content) {
                        // Рисуем текст
                        ctx.font = `${el.size}px '${el.font}', 'Segoe UI Emoji', 'Apple Color Emoji', sans-serif`;
                        ctx.fillStyle = el.color;
                        ctx.textAlign = 'center';
                        ctx.textBaseline = 'middle';
                        ctx.shadowColor = 'rgba(255, 105, 180, 0.5)';
                        ctx.shadowBlur = 15;
                        ctx.shadowOffsetX = 2;
                        ctx.shadowOffsetY = 2;
                        ctx.fillText(el.content, 0, 0);
                    }
                    
                    ctx.restore();
                }
                
                requestAnimationFrame(update);
            }

            // Обновление позиций
            function update() {
                for (let el of elements) {
                    el.x += el.vx;
                    el.y += el.vy;

                    // Отскок от краёв
                    if (el.x < 0) { el.x = 0; el.vx *= -0.9; el.vy += (Math.random() - 0.5) * 0.2; }
                    if (el.x > width) { el.x = width; el.vx *= -0.9; el.vy += (Math.random() - 0.5) * 0.2; }
                    if (el.y < 0) { el.y = 0; el.vy *= -0.9; el.vx += (Math.random() - 0.5) * 0.2; }
                    if (el.y > height) { el.y = height; el.vy *= -0.9; el.vx += (Math.random() - 0.5) * 0.2; }

                    // Лёгкая хаотичность
                    if (Math.random() < 0.005) {
                        el.vx += (Math.random() - 0.5) * 0.5;
                        el.vy += (Math.random() - 0.5) * 0.5;
                    }

                    // Ограничение скорости
                    const maxSpeed = 2.8;
                    if (Math.abs(el.vx) > maxSpeed) el.vx = Math.sign(el.vx) * maxSpeed;
                    if (Math.abs(el.vy) > maxSpeed) el.vy = Math.sign(el.vy) * maxSpeed;
                }
                
                draw();
            }

            requestAnimationFrame(update);

            // ---- Обработка касаний и кликов ----
            function handleInteraction(e) {
                e.preventDefault();

                let clientX, clientY;
                if (e.touches) {
                    clientX = e.touches[0].clientX;
                    clientY = e.touches[0].clientY;
                } else {
                    clientX = e.clientX;
                    clientY = e.clientY;
                }

                const rect = canvas.getBoundingClientRect();
                const scaleX = canvas.width / rect.width;
                const scaleY = canvas.height / rect.height;

                const mouseX = (clientX - rect.left) * scaleX;
                const mouseY = (clientY - rect.top) * scaleY;

                // Поиск ближайшего элемента
                let closestDist = 100;
                let closestIndex = -1;

                for (let i = 0; i < elements.length; i++) {
                    const el = elements[i];
                    const radius = el.size * 0.6;
                    const dx = mouseX - el.x;
                    const dy = mouseY - el.y;
                    const dist = Math.sqrt(dx*dx + dy*dy);
                    if (dist < radius && dist < closestDist) {
                        closestDist = dist;
                        closestIndex = i;
                    }
                }

                if (closestIndex !== -1) {
                    // Превращаем в сердечко
                    const heartImages = images.filter(img => img.type === 'heart');
                    if (heartImages.length > 0) {
                        const randomHeart = heartImages[Math.floor(Math.random() * heartImages.length)];
                        elements[closestIndex].imgData = randomHeart;
                        elements[closestIndex].type = 'heart';
                        elements[closestIndex].content = null; // убираем текст, если был
                        elements[closestIndex].size = randomHeart.size * (0.9 + Math.random() * 0.4);
                        // Эффект пульса
                        elements[closestIndex].size *= 1.5;
                        setTimeout(() => {
                            elements[closestIndex].size /= 1.5;
                        }, 150);
                    }
                }
            }

            canvas.addEventListener('click', handleInteraction);
            canvas.addEventListener('touchstart', handleInteraction, { passive: false });
            canvas.addEventListener('contextmenu', (e) => e.preventDefault());

            // Добавляем новые элементы время от времени
            setInterval(() => {
                if (elements.length < 50) {
                    elements.push(createRandomElement());
                }
            }, 6000);
        })();
    </script>
</body>
</html>
