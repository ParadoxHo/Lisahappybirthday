<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>С днём рождения, Лиза!</title>
<link href="https://fonts.googleapis.com/css2?family=Great+Vibes&family=Caveat:wght@400..700&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
body{
    min-height:100vh;
    background:linear-gradient(145deg,#ffd0dd,#ffb6c1,#ff9eb5,#ff85a5,#ffb6d9);
    background-size:400% 400%;
    animation:gradientBG 10s ease infinite;
    font-family:'Caveat';
    display:flex;
    align-items:center;
    justify-content:center;
    overflow:hidden;
}
@keyframes gradientBG{
    0%{background-position:0}
    50%{background-position:100%}
    100%{background-position:0}
}
.title{
    position:absolute;
    top:10px;
    width:100%;
    text-align:center;
    font-family:'Great Vibes';
    font-size:clamp(3rem,10vw,5rem);
    color:#8b1e5f;
    animation:glow 4s infinite;
    z-index:5;
}
@keyframes glow{
    0%,100%{filter:drop-shadow(0 0 3px #ff9eb5);}
    50%{filter:drop-shadow(0 0 8px #ff4080);}
}
.hint{
    position:absolute;
    bottom:15px;
    left:20px;
    background:rgba(255,240,245,.7);
    padding:.4rem .9rem;
    border-radius:40px;
    font-size:clamp(1.3rem,4vw,1.7rem);
    color:#a53f6c;
    z-index:5;
}
canvas{
    position:absolute;
    width:100vw;
    height:100vh;
}
</style>
</head>
<body>
<h1 class="title">С днём рождения, Лиза</h1>
<div class="hint">👉</div>
<canvas id="birthdayCanvas"></canvas>

<script>
(function(){
const canvas=document.getElementById("birthdayCanvas");
const ctx=canvas.getContext("2d");

let width,height,dpr;
function resize(){
    width=window.innerWidth;
    height=window.innerHeight;
    dpr=window.devicePixelRatio||1;
    canvas.width=width*dpr;
    canvas.height=height*dpr;
    canvas.style.width=width+"px";
    canvas.style.height=height+"px";
    ctx.setTransform(dpr,0,0,dpr,0,0);
}
window.addEventListener("resize",resize);
resize();

// ================== Фоновая музыка ==================
let bgMusic=null;
let bgGain=null;
let audioCtx=null;

// ================== ЗВУК ПОП ==================
function playPop(){
    new Audio('icons/pop.mp3').play().catch(()=>{});
}

// ================== ЧАСТИЦЫ ==================
let particles=[]; let waves=[];
function createParticles(x,y){
    for(let i=0;i<25;i++){
        let a=Math.random()*6.28;
        let s=1.5+Math.random()*3;
        particles.push({x,y,vx:Math.cos(a)*s,vy:Math.sin(a)*s,life:1,size:4+Math.random()*4});
    }
    waves.push({x,y,r:8,life:1});
}

// ================== ИЗОБРАЖЕНИЯ ==================
const imageFiles=[
    // коты
    'cat1.png','cat2.png','cat3.png','cat4.png','cat5.png',
    // сердечки
    'heart1.png','heart2.png','heart3.png',
    // цветы
    'flower1.png','flower2.png','flower3.png',
    // вкусняшки
    'yummy1.png','yummy2.png','yummy3.png',
    // подарки (gift)
    'gift1.png','gift2.png','gift3.png',
    // трусики
    'panties1.png','panties2.png','panties3.png',
    // новые present (для превращения подарков)
    'present1.png','present2.png','present3.png',
    // скелетики
    'skel1.png','skel2.png','skel3.png'
];

let regularImages = [];      // все обычные картинки (кроме present и skel)
let skelImages = [];        // скелетики
let presentImages = [];      // present*.png для подарков
let imagePool = [];          // пул обычных картинок для появления
let imageIndex = 0;
let loadedCount = 0;
let totalImages = imageFiles.length;

function shuffleImages(){
    if (regularImages.length === 0) {
        console.warn('Нет обычных изображений для создания пула');
        imagePool = [];
        return;
    }
    imagePool = [...regularImages];
    for(let i=imagePool.length-1;i>0;i--){
        let j=Math.floor(Math.random()*(i+1));
        [imagePool[i],imagePool[j]]=[imagePool[j],imagePool[i]];
    }
    imageIndex = 0;
}

function ready(){
    loadedCount++;
    if(loadedCount === totalImages){
        console.log('Все изображения загружены. Обычных:', regularImages.length, 'Скелетиков:', skelImages.length, 'Подарков:', presentImages.length);
        shuffleImages();
        start();
    }
}

imageFiles.forEach(f => {
    let img = new Image();
    img.src = "icons/" + f;
    img.onload = ready;
    img.onerror = () => {
        console.warn('Ошибка загрузки:', f);
        ready(); // всё равно считаем, чтобы не блокировать
    };

    if (f.startsWith('skel')) {
        skelImages.push(img);
    } else if (f.startsWith('present')) {
        presentImages.push(img);
    } else {
        regularImages.push(img);
    }
});

// ================== ЭЛЕМЕНТЫ ==================
let elements = [];
let time = 0;
const wishes = ["Счастья","Любви","Нежности","Радости","Улыбок","Тепла","Мечты"];

// ================== РУКА-УКАЗАТЕЛЬ ==================
let hand = null;
let firstClickDone = false;

function findCat1() {
    for (let i = 0; i < elements.length; i++) {
        let el = elements[i];
        if (el.type === 'img' && !el.fly && el.img.src && el.img.src.includes('cat1.png')) {
            return i;
        }
    }
    return -1;
}

function createHand() {
    if (firstClickDone) return;
    let idx = findCat1();
    if (idx !== -1) {
        hand = {
            targetIndex: idx,
            offsetX: -70,
            offsetY: -20,
            phase: Math.random() * Math.PI * 2,
            scale: 1,
        };
    }
}

function updateHand() {
    if (!hand || firstClickDone) return;
    let target = elements[hand.targetIndex];
    if (!target || target.fly || (target.type === 'img' && !target.img.src.includes('cat1.png'))) {
        let newIdx = findCat1();
        if (newIdx !== -1) {
            hand.targetIndex = newIdx;
        } else {
            hand = null;
        }
        return;
    }
    hand.phase += 0.05;
    hand.scale = 1 + Math.sin(hand.phase * 2) * 0.1;
}

// ================== СОЗДАНИЕ НОВОГО ЭЛЕМЕНТА ==================
function create(){
    let side=Math.floor(Math.random()*4);
    let x,y,m=120;
    if(side===0){x=-m;y=Math.random()*height;}
    if(side===1){x=width+m;y=Math.random()*height;}
    if(side===2){x=Math.random()*width;y=-m;}
    if(side===3){x=Math.random()*width;y=height+m;}
    let dx=width/2-x, dy=height/2-y;
    let len=Math.hypot(dx,dy);
    let speed=0.6+Math.random()*1.4;
    let vx=dx/len*speed, vy=dy/len*speed;

    if(Math.random()>.5){
        // Создаём картинку из пула обычных изображений
        if (regularImages.length === 0) {
            console.warn('Нет обычных картинок, создаём текст');
            // Если нет картинок, создаём текст
            return {type:'text',text:wishes[Math.floor(Math.random()*wishes.length)],x,y,vx:vx*0.5,vy:vy*0.5,size:45+Math.random()*15,rot:Math.random(),rs:(Math.random()-.5)*.01,opacity:0,phase:Math.random()*6,fly:false};
        }
        if (imagePool.length === 0) shuffleImages();
        if (imagePool.length === 0) return null; // всё плохо
        let img = imagePool[imageIndex++];
        if(imageIndex >= imagePool.length) shuffleImages();
        return {type:'img',img,x,y,vx:vx*0.5,vy:vy*0.5,size:85+Math.random()*25,rot:Math.random(),rs:(Math.random()-.5)*.01,opacity:0,phase:Math.random()*6,fly:false};
    }
    // Текстовое пожелание
    return {type:'text',text:wishes[Math.floor(Math.random()*wishes.length)],x,y,vx:vx*0.5,vy:vy*0.5,size:45+Math.random()*15,rot:Math.random(),rs:(Math.random()-.5)*.01,opacity:0,phase:Math.random()*6,fly:false};
}

// ================== СТАРТ ==================
function start(){
    let c=Math.min(45,width*height/18000);
    for(let i=0;i<c;i++) {
        let el = create();
        if (el) elements.push(el);
    }
    setTimeout(() => { createHand(); }, 500);
    let checkInterval = setInterval(() => {
        if (!hand && !firstClickDone) {
            createHand();
        }
        if (firstClickDone) {
            clearInterval(checkInterval);
            hand = null;
        }
    }, 2000);
    loop();
}

// ================== ЦИКЛ ==================
function loop(){ update(); draw(); requestAnimationFrame(loop); }

// ================== ОБНОВЛЕНИЕ ==================
function update(){
    time+=.1;
    let max=2.2;
    for(let i=elements.length-1;i>=0;i--){
        let e=elements[i];
        e.x+=e.vx; e.y+=e.vy;
        if(!e.fly){e.vx*=1.002;e.vy*=1.002;}
        e.vx*=.999;e.vy*=.999;
        if(e.vx>max)e.vx=max;if(e.vx<-max)e.vx=-max;
        if(e.vy>max)e.vy=max;if(e.vy<-max)e.vy=-max;
        e.rot+=e.rs;
        if(e.opacity<1)e.opacity+=.02;

        if(e.fly){
            e.vy-=0.1;
            e.vx*=0.99;
            e.rot=0; e.rs=0;
        }

        if(e.fly && e.y<-200){elements.splice(i,1); continue;}
        if(!e.fly){if(e.x<0)e.x=width;if(e.x>width)e.x=0;if(e.y<0)e.y=height;if(e.y>height)e.y=0;}
    }

    particles.forEach(p=>{p.x+=p.vx;p.y+=p.vy;p.vy+=.04;p.life-=.02;p.size*=.97;});
    waves.forEach(w=>{w.r+=5;w.life-=.03;});
    particles=particles.filter(p=>p.life>0);
    waves=waves.filter(w=>w.life>0);

    if(elements.length<35) {
        let el = create();
        if (el) elements.push(el);
    }

    updateHand();
}

// ================== РИСОВАНИЕ ==================
function draw(){
    ctx.clearRect(0,0,width,height);
    elements.forEach(e=>{
        ctx.save(); ctx.globalAlpha=e.opacity; ctx.translate(e.x,e.y); ctx.rotate(e.rot);
        let scale=1+.25*Math.sin(time*.05+e.phase);
        let s=e.size*scale;
        if(e.type==='img') {
            if (e.img.complete) {
                ctx.drawImage(e.img,-s/2,-s/2,s,s);
            }
        }
        else{ctx.font=s+"px Great Vibes";ctx.fillStyle="#ff4da6";ctx.textAlign="center";ctx.textBaseline="middle";ctx.fillText(e.text,0,0);}
        ctx.restore();
    });

    if (hand && !firstClickDone) {
        let target = elements[hand.targetIndex];
        if (target && !target.fly) {
            ctx.save();
            ctx.globalAlpha = 0.9;
            ctx.translate(target.x + hand.offsetX, target.y + hand.offsetY);
            ctx.scale(hand.scale, hand.scale);
            ctx.font = "60px 'Segoe UI Emoji', 'Apple Color Emoji', 'Noto Color Emoji', sans-serif";
            ctx.fillStyle = "#ff3388";
            ctx.shadowColor = "rgba(255, 20, 100, 0.5)";
            ctx.shadowBlur = 15;
            ctx.shadowOffsetX = 3;
            ctx.shadowOffsetY = 3;
            ctx.textAlign = "center";
            ctx.textBaseline = "middle";
            ctx.fillText("👉", 0, 0);
            ctx.restore();
        } else {
            createHand();
        }
    }

    particles.forEach(p=>{ctx.save();ctx.globalAlpha=p.life;ctx.beginPath();ctx.arc(p.x,p.y,p.size,0,6.28);ctx.fillStyle="#ff6fa8";ctx.fill();ctx.restore();});
    waves.forEach(w=>{ctx.save();ctx.globalAlpha=w.life;ctx.beginPath();ctx.arc(w.x,w.y,w.r,0,6.28);ctx.strokeStyle="#ff9eb5";ctx.lineWidth=2;ctx.stroke();ctx.restore();});
}

// ================== КЛИК ==================
canvas.addEventListener("click",e=>{
    if(!bgMusic){
        audioCtx = new (window.AudioContext || window.webkitAudioContext)();
        bgMusic = new Audio('icons/q.mp3');
        const track = audioCtx.createMediaElementSource(bgMusic);
        bgGain = audioCtx.createGain();
        bgGain.gain.value=0;
        track.connect(bgGain).connect(audioCtx.destination);
        bgMusic.loop=true;
        bgMusic.play().then(()=>fadeInMusic());
    }

    let rect=canvas.getBoundingClientRect();
    let x=e.clientX-rect.left, y=e.clientY-rect.top;
    let r2=40*40;
    let candidates=[];
    elements.forEach((el,i)=>{ if(el.fly) return; let dx=x-el.x, dy=y-el.y; if(dx*dx+dy*dy<r2) candidates.push(i); });

    if(candidates.length){
        if (!firstClickDone) {
            firstClickDone = true;
            hand = null;
        }

        playPop();
        let id=candidates[Math.floor(Math.random()*candidates.length)];
        let el=elements[id];
        createParticles(el.x,el.y);

        // Определяем, во что превращать
        let newImg = null;
        if (el.type === 'img' && el.img.src.includes('gift')) {
            // Если это подарок (gift), превращаем в случайный present
            if (presentImages.length > 0) {
                newImg = presentImages[Math.floor(Math.random() * presentImages.length)];
            } else {
                console.warn('Нет present-изображений, используется скелетик');
                if (skelImages.length > 0) {
                    newImg = skelImages[Math.floor(Math.random() * skelImages.length)];
                }
            }
        } else {
            // Все остальные — в скелетик
            if (skelImages.length > 0) {
                newImg = skelImages[Math.floor(Math.random() * skelImages.length)];
            }
        }

        if (newImg) {
            el.type = 'img';
            el.img = newImg;
            el.fly = true;
            el.vy = -12 - Math.random() * 6;
            el.vx = (Math.random() - 0.5) * 1.5;
            el.size *= 1.25;
            setTimeout(() => { el.size /= 1.25; }, 150);
        } else {
            console.warn('Не удалось выбрать изображение для превращения, объект остаётся без изменений');
        }

        setTimeout(() => {
            let newEl = create();
            if (newEl) elements.push(newEl);
        }, 600);
    }
});

setInterval(()=>{
    if(elements.length<65) {
        let el = create();
        if (el) elements.push(el);
    }
},4000);

// ================== ПЛАВНОЕ УВЕЛИЧЕНИЕ ГРОМКОСТИ ДО 3.5 (УСКОРЕННОЕ) ==================
function fadeInMusic(){
    if(bgGain){
        let target=3.5;
        let step=0.01; // Увеличено с 0.002 до 0.01 для более быстрого нарастания
        let interval=setInterval(()=>{
            if(bgGain.gain.value<target){
                bgGain.gain.value=Math.min(bgGain.gain.value+step,target);
            } else clearInterval(interval);
        },50);
    }
}
})();
</script>
</body>
</html>
